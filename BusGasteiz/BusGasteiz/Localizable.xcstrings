        },
        "eu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "[PROBA] Autobusak ibilbide alternatibo bat jarraituko du eta ez da aurreikusitako geltoki guztietan geldituko."
          }
        }
      }
    },
