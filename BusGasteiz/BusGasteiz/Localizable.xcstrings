    "Randomly assigns fake service alerts (30% probability) to stops and routes. Only visible in debug builds." : {
      "comment" : "Footer text for the debug Testing section in the About screen",
      "extractionState" : "stale",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Asigna alertas de servicio ficticias (probabilidad del 30%) a paradas y líneas de forma aleatoria. Solo aparece en compilaciones de depuración."
          }
        },
        "eu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aleatorioki esleitze ditu alerta fiktizio (% 30 probabilitate) geltoki eta lineetara. Arazketa eraikuntza bertsioetan bakarrik agertzen da."
