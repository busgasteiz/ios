    "[TEST] The bus will follow an alternative route and will not stop at all scheduled stops." : {
      "comment" : "Fake alert description for debug simulation",
      "extractionState" : "stale",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
